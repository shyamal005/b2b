PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Relative paths are resolved from the backend/ folder (not shell cwd).
DATABASE_PATH=./data.sqlite

# --- Option A: one server (build UI, then serve it from Node) ---
# After `npm run build` from the repo root, this points at the Vite output:
STATIC_DIR=../frontend/dist

# Comma-separated origins for CORS (only if UI and API are on different hosts).
# CORS_ORIGINS=https://your-frontend.example.com
